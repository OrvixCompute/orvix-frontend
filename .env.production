# Production public config, baked into the client bundle at `next build`.
# The frontend is served over HTTPS at orvix.network, so the API must be called
# over HTTPS same-origin (nginx proxies /v1 -> orchestrator on :8000). Using the
# raw http://IP here would be blocked by browsers as mixed content.
NEXT_PUBLIC_API_URL=https://orvix.network
NEXT_PUBLIC_SITE_URL=https://orvix.network
NEXT_PUBLIC_SOLANA_NETWORK=mainnet-beta
NEXT_PUBLIC_SOLANA_RPC=https://api.mainnet-beta.solana.com
NEXT_PUBLIC_ORVX_MINT=
NEXT_PUBLIC_TREASURY_ADDRESS=
NEXT_PUBLIC_USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
NEXT_PUBLIC_INCINERATOR=1nc1nerator11111111111111111111111111111111
